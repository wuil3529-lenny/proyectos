# ============================================================================
# ARCHIVO .ENV - CONFIGURACIÓN DEL PROYECTO
# ============================================================================
#
# IMPORTANTE: Este archivo contiene datos sensibles.
# NUNCA commitear a Git. Agregar a .gitignore
#
# Crear un archivo llamado ".env" en la raíz del proyecto con este contenido
# Cambiar valores según tu entorno
#

# ============================================================================
# BASE DE DATOS PostgreSQL
# ============================================================================

# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
# Para desarrollo local
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/fabrica_produccion

# Para producción on-premise del cliente
# DATABASE_URL=postgresql://admin:contraseña_segura@192.168.1.100:5432/fabrica_produccion

# Alternativa: Si usas variables separadas
# DB_USER=postgres
# DB_PASSWORD=tu_contraseña
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=fabrica_produccion


# ============================================================================
# SEGURIDAD JWT
# ============================================================================

# IMPORTANTE: Generar una clave aleatoria segura
# En Linux/Mac: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# En Windows: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Nunca usar la misma clave en producción y desarrollo

# Clave secreta para firmar JWT tokens
SECRET_KEY=tu-clave-super-secreta-cambiar-inmediatamente-en-produccion-123456789

# Algoritmo para JWT (no cambiar a menos que sepas qué haces)
JWT_ALGORITHM=HS256

# Minutos que dura el token antes de expirar
JWT_EXPIRATION_MINUTES=30


# ============================================================================
# ENTORNO (development / production)
# ============================================================================

# development = Muestra errores detallados, reload automático
# production  = Optimizado, sin detalles en errores
ENVIRONMENT=development

# En desarrollo: True (muestra SQL en consola)
# En producción: False (mejor rendimiento)
DEBUG_MODE=True


# ============================================================================
# SERVIDOR
# ============================================================================

# Host donde corre la aplicación
APP_HOST=0.0.0.0

# Puerto
APP_PORT=8000

# Nombre de la aplicación
APP_NAME=Plataforma Industrial - Gestión Producción

# Versión
APP_VERSION=1.0.0


# ============================================================================
# EMAIL (Para notificaciones y reportes)
# ============================================================================

# Proveedor: gmail, outlook, office365, custom
EMAIL_PROVIDER=gmail

# Dirección de email que envía notificaciones
EMAIL_FROM=notificaciones@fabrica.com

# Contraseña o App Password (no contraseña normal si usa Gmail)
EMAIL_PASSWORD=tu_app_password_aqui

# Servidor SMTP (si no usas uno de los preconfigurados)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_TLS=True

# Email del administrador para reportes críticos
ADMIN_EMAIL=gerente@fabrica.com


# ============================================================================
# NOTIFICACIONES (Push notifications)
# ============================================================================

# Firebase Cloud Messaging (para notificaciones push a celulares)
# FIREBASE_API_KEY=tu_firebase_api_key_aqui
# FIREBASE_PROJECT_ID=tu_proyecto_firebase

# Telegram Bot (alternativa para alertas críticas)
# TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
# TELEGRAM_CHAT_ID=tu_chat_id_aqui


# ============================================================================
# BACKUP Y CLOUD STORAGE
# ============================================================================

# Google Drive (para backups opcionales)
# GOOGLE_DRIVE_FOLDER_ID=tu_folder_id_aqui
# GOOGLE_CREDENTIALS_JSON=/path/to/credentials.json

# OneDrive
# ONEDRIVE_CLIENT_ID=tu_client_id
# ONEDRIVE_CLIENT_SECRET=tu_secret

# Dropbox
# DROPBOX_ACCESS_TOKEN=tu_token_aqui

# Directorio local para backups automáticos
BACKUP_LOCAL_PATH=/home/usuario/backups_fabrica


# ============================================================================
# INTELIGENCIA ARTIFICIAL (ML Models)
# ============================================================================

# Ruta donde se guardan modelos entrenados
ML_MODELS_PATH=/home/usuario/models

# Reentrenamiento automático cada N ciclos
ML_RETRAIN_EVERY_N_CYCLES=100

# Ruta de datos históricos para entrenamiento
ML_TRAINING_DATA_PATH=/home/usuario/data/historico


# ============================================================================
# CORS (Para acceso desde frontend)
# ============================================================================

# Dominios permitidos (separados por coma)
# En desarrollo: * (todos)
# En producción: especificar dominios exactos
CORS_ORIGINS=*

# O específicamente:
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://app.fabrica.com


# ============================================================================
# LOGGING
# ============================================================================

# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Ruta del archivo de logs
LOG_FILE=/home/usuario/logs/app.log


# ============================================================================
# DATOS DE EJEMPLO (para testing)
# ============================================================================

# Usuario administrador por defecto (se crea en startup)
DEFAULT_ADMIN_EMAIL=admin@fabrica.com
DEFAULT_ADMIN_PASSWORD=Admin@123456

# Crear datos de prueba al iniciar (development solo)
CREATE_SAMPLE_DATA=True


# ============================================================================
# INTEGRACIÓN CON MÁQUINAS (Fase 2)
# ============================================================================

# MQTT Broker (para sensores IoT)
# MQTT_BROKER_HOST=192.168.1.50
# MQTT_BROKER_PORT=1883
# MQTT_USERNAME=mqtt_user
# MQTT_PASSWORD=mqtt_password
# MQTT_TOPICS=fabrica/maquinas/+/datos

# Modbus TCP (para controladores PLC)
# MODBUS_SERVER_HOST=192.168.1.60
# MODBUS_SERVER_PORT=502


# ============================================================================
# OPCIONAL: SENTRY (Monitoreo de errores en producción)
# ============================================================================

# SENTRY_DSN=https://your_key@sentry.io/your_project_id


# ============================================================================
# NOTAS IMPORTANTES:
# ============================================================================
#
# 1. SEGURIDAD:
#    - Nunca commitear .env a Git
#    - Agregar ".env" a .gitignore
#    - En producción, usar un gestor de secretos (AWS Secrets, HashiCorp Vault)
#    - Cambiar SECRET_KEY en cada entorno
#
# 2. CONTRASEÑAS:
#    - Para Gmail: generar "App Password" (no la contraseña normal)
#    - Para PostgreSQL: usar contraseña fuerte
#    - Cambiar DEFAULT_ADMIN_PASSWORD después de primera instalación
#
# 3. DESARROLLO vs PRODUCCIÓN:
#    - Archivo .env.development para desarrollo
#    - Archivo .env.production para producción (en servidor cliente)
#    - Nunca usar same SECRET_KEY en ambos
#
# 4. SENSIBILIDAD:
#    - DATABASE_URL contiene credenciales
#    - SECRET_KEY es crítico para seguridad JWT
#    - EMAIL_PASSWORD puede ser app-specific
#    - Guardar estas variables de forma segura
#
