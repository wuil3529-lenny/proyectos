# ── Base de Datos PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://postgres:tu_contraseña@localhost:5432/fabrica_produccion

# ── Seguridad JWT ─────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CAMBIAR-ESTA-CLAVE-EN-PRODUCCION
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# ── Entorno ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG_MODE=True

# ── CORS ──────────────────────────────────────────────────────────
# development: *   |   production: https://tuapp.com
CORS_ORIGINS=*

# ── Admin por defecto (se crea al iniciar) ────────────────────────
DEFAULT_ADMIN_EMAIL=admin@fabrica.com
DEFAULT_ADMIN_PASSWORD=Admin@123456

# ── Email (opcional) ──────────────────────────────────────────────
# EMAIL_FROM=notificaciones@fabrica.com
# EMAIL_PASSWORD=app_password
